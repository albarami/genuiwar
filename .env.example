# GenUIWar environment template

APP_ENV=development
APP_NAME=genuiwar
APP_HOST=0.0.0.0
APP_PORT=8000
WEB_HOST=0.0.0.0
WEB_PORT=3000
LOG_LEVEL=INFO

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_REASONING_DEPLOYMENT=
AZURE_OPENAI_RESPONSES_MODEL_HINT=gpt-5.4
AZURE_OPENAI_ENABLE_REASONING=true
AZURE_OPENAI_ENABLE_STREAMING=true
AZURE_OPENAI_TIMEOUT_SECONDS=120

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/genuiwar
DATABASE_ECHO=false

REDIS_URL=redis://localhost:6379/0
QUEUE_BACKEND=redis
CACHE_BACKEND=redis

LOCAL_STORAGE_ROOT=./data
UPLOADS_DIR=./data/uploads
PARSED_DIR=./data/parsed
ARTIFACTS_DIR=./data/artifacts
EVAL_DATA_DIR=./data/evaluation
SYNTHETIC_DATA_DIR=./data/synthetic

RETRIEVAL_BACKEND=local
EMBEDDING_DIMENSIONS=3072
CHUNK_SIZE=1200
CHUNK_OVERLAP=200
TOP_K_DEFAULT=8
TOP_K_MAX=20

AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=
AZURE_SEARCH_SEMANTIC_CONFIG=

WORKER_ENABLED=true
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL_SECONDS=2

AUTH_MODE=local_dev
DEV_ADMIN_EMAIL=admin@example.com
DEV_ADMIN_PASSWORD=change-me

ENABLE_FILE_UPLOADS=true
ENABLE_RUN_REUSE=true
ENABLE_HYBRID_RUNS=true
ENABLE_FRESH_DEEP_RUNS=true
ENABLE_LIVE_EVENT_STREAM=true
ENABLE_DEBATE_TRACE=true
ENABLE_EVIDENCE_DRAWER=true
ENABLE_CALCULATION_TRACE=true
ENABLE_CLARIFICATION_QUESTIONS=true
ENABLE_ADJUDICATION_GATE=true
ENABLE_SYNTHETIC_DATA=true
ENABLE_EVALUATION_HARNESS=true

NO_FREE_FACTS=true
REQUIRE_CITATIONS=true
REQUIRE_CALCULATION_TRACE_FOR_NUMBERS=true
REQUIRE_CONFIDENCE_GRADES=true
ALLOW_QUESTION_CLARIFICATION=true
ALLOW_LOW_CONFIDENCE_FINALS=false

MAX_RUN_SECONDS=600
MAX_AGENT_STEPS_PER_RUN=100
MAX_DEBATE_ROUNDS=3
MAX_CLARIFICATION_QUESTIONS=3
RUN_REUSE_SIMILARITY_THRESHOLD=0.88

STREAM_TRANSPORT=sse
UI_MODE=generative
SHOW_AGENT_EVENTS=true
SHOW_DEBATE_EVENTS=true
SHOW_ADJUDICATION_EVENTS=true

ENABLE_STRUCTURED_LOGGING=true
ENABLE_AUDIT_LOGGING=true
ENABLE_RUN_EVENT_LOGGING=true
SENTRY_DSN=

TEST_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/genuiwar_test
GENERATE_SYNTHETIC_FIXTURES=true
SYNTHETIC_DATA_SEED=42

AGENT_MODE=deterministic
